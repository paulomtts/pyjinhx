{# python
from dataclasses import dataclass

from pyjinhx import BaseComponent


@dataclass
class SfcLabel:
    """A plain helper class (not a component) — allowed alongside the component."""

    text: str = "picked"


class SfcPicked(BaseComponent):
    label: str = SfcLabel().text
#}
<div class="sfc-picked">{{ label }}</div>
